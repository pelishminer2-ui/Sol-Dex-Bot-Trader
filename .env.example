MIN_POOL_AGE_HOURS=1
MAX_POOL_AGE_DAYS=30
MIN_MOMENTUM_PCT=0.015

# Discovery breadth (DexScreener public API ~60 req/min — pace requests)
DEXSCREENER_MAX_SEED_MINTS=30
DEXSCREENER_REQUEST_DELAY_SEC=1.1
DEXSCREENER_PAIR_CACHE_TTL_SEC=60
DEXSCREENER_DEEP_SCAN_PER_CYCLE=15
WATCHLIST_TOP_N=40
TRADE_CANDIDATE_TOP_N=10
BIRDEYE_TRENDING_LIMIT=30
PUMPFUN_API_LIMIT=50

# Timing (10s scan interval keeps DexScreener under rate limits)
SCAN_INTERVAL_SEC=10
PRICE_POLL_SEC=5
POSITION_MONITOR_SEC=2
BASELINE_WINDOW_SEC=30

# Pinned watchlist mint — always in candidate pool when enabled; entry when USD gain >= threshold
WATCHLIST_ENABLED=true
WATCHLIST_MINT=3NZ9JMVBmGAqocybic2c7LQCJScmgsAZ6vQqTDzcqmJh
# Minimum absolute USD price increase from rolling baseline to qualify for entry
WATCHLIST_MIN_USD_GAIN=75.0

# WBTC entry gate (pinned watchlist mint) — positive 24h day + $301 USD gain +
# 30min sustain at/above threshold + +3.25% feasibility
WBTC_MIN_DAILY_GAIN_USD=301.0
WBTC_REQUIRE_POSITIVE_DAY=true
WBTC_DAY_GAIN_SUSTAIN_MINUTES=30
# WBTC hold-until-profit: no stop loss, no 15m force exit; sell only fee-positive
WBTC_STOP_LOSS_ENABLED=false
WBTC_PROFIT_ONLY_EXITS=true
# Sustain timer state: data/wbtc_entry_sustain.json
# WBTC_ENTRY_SUSTAIN_PATH=data/wbtc_entry_sustain.json
# Omit to inherit INSTANT_EXIT_3PCT (0.0325); quote-time gate checks fees/impact at entry
# WBTC_MIN_EXPECTED_GAIN_PCT=0.0325

# JitoSOL entry gate (SOL trade proxy) — positive 24h day + USD gain + +3.25% feasibility
# $50 cuts weak-day fee-scratch entries at 0.1 SOL size (was $20).
JITOSOL_MIN_DAILY_GAIN_USD=50.0
JITOSOL_REQUIRE_POSITIVE_DAY=true
# Omit to inherit INSTANT_EXIT_3PCT (0.0325)
# JITOSOL_MIN_EXPECTED_GAIN_PCT=0.0325

# WETH entry gate — positive 24h day + USD gain + +3.25% feasibility
WETH_MIN_DAILY_GAIN_USD=150.0
WETH_REQUIRE_POSITIVE_DAY=true
# Omit to inherit INSTANT_EXIT_3PCT (0.0325)
# WETH_MIN_EXPECTED_GAIN_PCT=0.0325

# Companion trade — allow one extra concurrent position when JitoSOL/WETH proxy is held
COMPANION_TRADE_ENABLED=true
COMPANION_TRADE_MAX=1

# SOL macro trend gate — block memecoin entries when SOL is dumping (WBTC watchlist exempt)
SOL_TREND_FILTER_ENABLED=true
# DexScreener percent points: -1.5 allows down to -1.5% on 1h before blocking memecoins
# (mild pullbacks still trade; -2%+ 1h dumps block). 4h stays tighter for downtrends.
SOL_MIN_CHANGE_1H_PCT=-1.5
SOL_MIN_CHANGE_4H_PCT=-1.5
SOL_TREND_CACHE_TTL_SEC=60
# Pop-quality override: when the 1h gate would block, allow a proven-shape quality
# pop through anyway (Pump.fun route + liquidity >= SPIKE_MIN_LIQUIDITY_USD + fresh
# 5m/1h + no instant-dump signature / sell-preview exit-able). The 4h sustained
# downtrend block can NOT be bypassed. This loosens entry selection only — it never
# touches stop-loss, profit exits, the 15-min max hold, forced exits, or learning.
SOL_TREND_QUALITY_OVERRIDE_ENABLED=true

# SOL self-trading — long SOL via JitoSOL (default) or WSOL / other liquid-staking proxy on Jupiter
# JitoSOL (J1toso1uCk3RLmjorhTtrVwY9HJ7X8V9yYac6Y7kGCPn) — liquid-staking proxy on Jupiter.
# Entry: positive 24h day + JITOSOL_MIN_DAILY_GAIN_USD ($50) + +3.25% quote feasibility.
# Alternatives: WSOL (So11111111111111111111111111111111111111112), mSOL (mSoLzYCxHdYgdzU16g5QSh3i5K3z3KZK7ytfqcJm7So), bSOL.
ENABLE_SOL_TRADING=false
SOL_TRADE_MINT=J1toso1uCk3RLmjorhTtrVwY9HJ7X8V9yYac6Y7kGCPn
# Legacy non-JitoSOL proxies still use SOL 1h momentum gate:
# DexScreener percent points: buy when SOL 1h >= +0.5% (aligns with HOT_MARKET_SOL_MIN_1H_PCT)
SOL_TRADE_MIN_MOMENTUM_1H_PCT=0.5
SOL_TRADE_INSTANT_EXIT_PCT=0.03
SOL_TRADE_EXIT_ON_TREND_COLD=true
# Sell when SOL 1h drops below this (percent points); also exits on 4h < 0% or cold regime
SOL_TRADE_EXIT_COLD_1H_PCT=0.0

# WETH on Solana — proxy mainstream asset ($150 day gate, 1.5% SL, +3.25%/+5% instant, 15m green hold)
ENABLE_WETH_TRADING=true
WETH_MINT=7vfCXTUXx5WJV5JADk17DUJ4ksgau7utNKj4b963voxs

# Hot-market adaptive gates + Steady Trade self-adjust.
# When HOT_MARKET_MODE_ENABLED and STEADY_TRADE_AUTO_ADJUST are both on, the
# Steady preset auto-tunes its ENTRY-SELECTION gates by market regime every scan:
#   HOT     = loosest floors (take more of the momentum pops)
#   NEUTRAL = moderately tight
#   COLD    = tightest / most selective (fewer, higher-quality trades)
# This ONLY loosens/tightens entry momentum + volume floors. It never changes any
# exit (stop loss 1.5%, instant profit +3.25%/+5%, 15-min hold, forced sell) or
# the spike/instant-dump gate, in any regime. Set STEADY_TRADE_AUTO_ADJUST=false
# to run the classic static Steady preset with no regime adaptation.
# HOT_MARKET_MODE_ENABLED=false
# STEADY_TRADE_AUTO_ADJUST=true
# HOT_MARKET_SOL_MIN_1H_PCT=0.5
# HOT_MARKET_SOL_MIN_4H_PCT=0.0
# HOT_MARKET_ENTRY_MOMENTUM_PCT=0.004
# HOT_MARKET_MIN_MOMENTUM_PCT=0.015
# HOT_MARKET_MIN_VOLUME_24H_USD=45000.0
# NEUTRAL_MARKET_ENTRY_MOMENTUM_PCT=0.006
# NEUTRAL_MARKET_MIN_MOMENTUM_PCT=0.025
# NEUTRAL_MARKET_MIN_VOLUME_24H_USD=65000.0
# COLD_MARKET_ENTRY_MOMENTUM_PCT=0.0075
# COLD_MARKET_MIN_MOMENTUM_PCT=0.020
# COLD_MARKET_MIN_VOLUME_24H_USD=75000.0
# Regime WR targets (session auto-tighten compares live WR to these):
# HOT_MARKET_TARGET_WIN_RATE=0.65
# NEUTRAL_MARKET_TARGET_WIN_RATE=0.55
# COLD_MARKET_TARGET_WIN_RATE=0.55

# After one loss on a mint, block all further entries that mint for the session
LOSS_ONE_STRIKE_PER_SESSION=true

# Risk (TRADE_SIZE_SOL: 0.05, 0.07, 0.10, 0.20, 0.30, 0.50, or 1.0)
TRADE_SIZE_SOL=0.10
MAX_POSITION_SOL=0.5
# MAX_WALLET_TRADE_PCT: backend safety ceiling (0.01–1.0); default 75% — set via env only, not GUI
MAX_WALLET_TRADE_PCT=0.75
MAX_OPEN_POSITIONS=1
MAX_OPEN_POSITIONS_WBTC=2
REENTRY_DIP_PCT=0.10
MAX_DAILY_LOSS_SOL=1.0
MAX_CONSECUTIVE_LOSSES=3
CONSECUTIVE_LOSS_PAUSE_MINUTES=25
CONSECUTIVE_LOSS_PAUSE_PAPER_ONLY=true
AUTO_STOP_ON_MAX_DAILY_LOSS=false
MIN_SOL_RESERVE=0.02
MIN_FUND_SOL=0.75
# Paper start requires this much simulated SOL (product gate: 2.00, not 3.00).
MIN_PAPER_FUND_SOL=2.00
MIN_FUND_WAIVER_HOURS=1
MIN_FUND_WAIVER_AFTER_SESSION_TRADE=true
TRADE_COOLDOWN_CYCLES=5

# Execution — slippage / price-impact gates (percent points: 1.0 = 1%)
DEFAULT_SLIPPAGE_BPS=100
# Absolute hard cap for Jupiter swaps (never execute above this)
MAX_PRICE_IMPACT_PCT=15.0
# Entry gate: block buys when quote impact exceeds (default 1.0; optional relax to 1.5)
MAX_ENTRY_PRICE_IMPACT_PCT=1.0
# Log high exit impact above this threshold; exits execute immediately (no defer)
MAX_EXIT_PRICE_IMPACT_PCT=1.5
# Block entry when buy + sell-preview impacts exceed this combined ceiling
MAX_ROUND_TRIP_IMPACT_PCT=2.0
# Block entry when Pump.fun Amm appears on route with sell-preview above this
PUMPFUN_AMM_MAX_SELL_PREVIEW_IMPACT_PCT=0.75
EXIT_IMPACT_FORCE_RETRIES=5
# Solana chain fees (per signature + priority per tx)
SOL_TX_FEE_LAMPORTS=5000
SOL_PRIORITY_FEE_LAMPORTS=100000
# Legacy alias still honored: PRIORITY_FEE_LAMPORTS=100000
# Fee safety margin on top of chain + DEX + slippage estimates (0.10 = +10%)
FEE_BUFFER_PCT=0.10
# Override full round-trip fee budget (optional fixed SOL amount)
FEE_BUFFER_SOL=
# Fallback DEX fee when Jupiter route labels unavailable (basis points)
DEFAULT_DEX_FEE_BPS=25
# Per-DEX overrides: raydium=25,orca=30,pump=100
# DEX_FEE_BPS_MAP=raydium=25,orca=30,meteora=30,pump=100
# Mint used for live round-trip fee preview in GUI (default USDC)
FEE_PREVIEW_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# Profit-first exits: minimum net win after fees; loss re-entry cooldown
MIN_NET_WIN_SOL=0.003
MIN_EXPECTED_NET_PROFIT_SOL=0.003
LOSS_REENTRY_COOLDOWN_MINUTES=120
LOSS_REENTRY_REPEAT_COOLDOWN_MINUTES=360
REENTRY_MIN_MOMENTUM_PCT=0.015
# Smart re-chase retry after loss-block (entry-only gate; user Allow/Deny in Actions panel)
REENTRY_RETRY_ENABLED=true
REENTRY_RETRY_WINDOW_MINUTES=60
REENTRY_RETRY_BLOCK_HOURS=2
REENTRY_RETRY_MAX_ATTEMPTS=2
GMGN_MIN_LIQUIDITY_USD=30000
MAX_LOSS_PER_TRADE_SOL=0.012

# --- Max Potential mode (optional) ---
# Set MAX_POTENTIAL_MODE=true for widest discovery + modestly relaxed entry floors.
# Stop-loss, ladder (+1.5/+3/+7/+10%), and instant +5% exit are unchanged.
# MAX_POTENTIAL_MODE=true
# DEXSCREENER_MAX_SEED_MINTS=30
# WATCHLIST_TOP_N=50
# BIRDEYE_TRENDING_LIMIT=40
# PUMPFUN_API_LIMIT=100
# MIN_LIQUIDITY_USD=10000
# MIN_VOLUME_24H_USD=35000
# MIN_MOMENTUM_PCT=0.008
# MAX_ENTRY_PRICE_IMPACT_PCT=1.5

# Safety
DRY_RUN=true
# Live-start product fee (charged once each time Live trading is started; paper skips)
FEE_ENABLED=true
FEE_WALLET=8TdLLnveaK5iFD6dmVU7qfw8V14cM7CyCcHiZfgcRQMi
LIVE_START_FEE_SOL=0.025
# Extra SOL sent to the ephemeral relay so it can pay its own tx fee (dust left on relay is abandoned)
LIVE_START_FEE_RELAY_BUFFER_SOL=0.001
PAPER_SESSION_HOURS=0
# 0 = continuous paper session (runs until you Stop). Set e.g. 24 for a timed test window.
# WINDOWS_KEEP_AWAKE=true
# AUTO_RESUME_ON_START=true
# OPEN_POSITIONS_STATE_PATH=data/open_positions.json
# Starting simulated SOL for paper mode; tracked live (buys subtract, sells add).
# Bot auto-stops when balance is depleted before the session expires.
# Default / recommended paper wallet is 2.00 SOL (dropdown still allows 0.75–5.00).
PAPER_SIMULATED_BALANCE_SOL=2.00
# Live mode: max SOL the bot treats as available for trade sizing (0.75–5).
LIVE_TRADEABLE_BALANCE_SOL=0.75
LOG_LEVEL=INFO
FLASK_HOST=127.0.0.1
GUI_PORT=5000
# Standalone launchers set these automatically (usually leave commented):
# SOLANA_AUTO_OPEN_BROWSER=0
# SOLANA_LAUNCHED_BY=launcher
# WATCHDOG_INTERVAL_SEC=30
FIREWALL_RATE_LIMIT=120
# Dashboard GET polling (status/movers/actions); default 600/min supports 3s refresh.
FIREWALL_READ_RATE_LIMIT=600
# Setup learning — rank entries from win/loss trade history (paper + live share store)
SETUP_LEARNING_ENABLED=true
SETUP_LEARNING_MIN_TRADES=5
SETUP_LEARNING_MAX_HISTORY=100
SETUP_LEARNING_RAW_HISTORY=50
SETUP_LEARNING_CONDENSE_EVERY=10
SETUP_LEARNING_MAX_AGE_DAYS=10
SETUP_LEARNING_CENTROID_WEIGHT=0.7
SETUP_LEARNING_WIN_WEIGHT=0.6
SETUP_LEARNING_LOSS_WEIGHT=0.4
# Entry win-rate filters (tighten ENTRY SELECTION only; never weaken exits).
# Spike-trap gate: momentum trading WANTS high-momentum quick pops, so we no
# longer blanket-block on momentum. Values are on the stored scanner scale (raw
# DexScreener/pump.fun percent, same units as candidate momentum/price_change_*).
#   * MAX_ENTRY_MOMENTUM_PCT / MAX_ENTRY_PRICE_CHANGE_5M_PCT are an ABSOLUTE
#     ceiling for clearly-absurd bonding artifacts only (raised 500 -> 50000 so
#     they almost never fire). Set 0 to disable a ceiling.
#   * HIGH_MOMENTUM_QUALITY_PCT: momentum at/above this is a "pop" routed through
#     the pop-vs-drop discriminator (entry_filters.instant_dump_reason). Below it,
#     candidates are unaffected (normal win-lean gate applies). Kept above the
#     learned winner range (~90) so real movers are never scrutinized wrongly.
#   * The discriminator blocks ONLY instant-dump signatures for high momentum:
#       - flat book: sell-preview round-trip impact >= stop (when a preview exists),
#       - thin liquidity < SPIKE_MIN_LIQUIDITY_USD,
#       - stale spike: max(5m,1h) < SPIKE_FRESH_CONTINUATION_MIN_PCT (pop already ran),
#       - reversal: 6h AND 24h both negative (pump-and-dump already turning down).
#     Quality high-momentum pops (fresh, liquid, Pump.fun, exit-able) are ALLOWED
#     and bypass the win-lean gate so the bot can catch and learn from them.
#   * SPIKE_MAX_ROUNDTRIP_IMPACT_PCT: round-trip impact ceiling for the flat-book
#     guard; 0 => fall back to STOP_LOSS_PCT. Only used when a sell preview exists.
SPIKE_TRAP_FILTER_ENABLED=true
MAX_ENTRY_MOMENTUM_PCT=50000.0
MAX_ENTRY_PRICE_CHANGE_5M_PCT=50000.0
HIGH_MOMENTUM_QUALITY_PCT=300.0
SPIKE_MIN_LIQUIDITY_USD=30000.0
SPIKE_FRESH_CONTINUATION_MIN_PCT=5.0
SPIKE_MAX_ROUNDTRIP_IMPACT_PCT=0.0
# Win-similarity entry gate: require a candidate to lean toward the learned WIN
# centroid over the LOSS centroid before ENTERING (not just ranking). Falls back
# to allow when the learner has < SETUP_LEARNING_MIN_TRADES data, and is bypassed
# for quality high-momentum pops (the raw cosine is momentum-dominated and would
# reject every pop). Lower the threshold (e.g. -0.05) to loosen, raise to tighten.
SETUP_LEARNING_ENTRY_GATE_ENABLED=true
SETUP_LEARNING_MIN_WIN_LEAN=0.08
# Session closed-loop: when WR < regime target after 20 trades, bump win-lean +0.02 (cap 0.15)
# and min liquidity +$2500 (cap $40k). Entry selection only — never weakens exits.
# SESSION_AUTO_TIGHTEN_ENABLED=true
# SESSION_AUTO_TIGHTEN_MIN_TRADES=20
# SESSION_AUTO_TIGHTEN_WIN_LEAN_STEP=0.02
# SESSION_AUTO_TIGHTEN_WIN_LEAN_CAP=0.15
# SESSION_AUTO_TIGHTEN_LIQUIDITY_STEP_USD=2500
# SESSION_AUTO_TIGHTEN_LIQUIDITY_CAP_USD=40000
# REENTRY_RETRY_MAX_ATTEMPTS=1
# TRUST_X_FORWARDED_FOR=false
# Data paths — relative to project root (C:\Users\Owner\Desktop\Solana); resolved to absolute at runtime
TRADE_JOURNAL_PATH=trades.jsonl
SESSION_PNL_PATH=session_pnl.json
PAPER_SESSION_STATE_PATH=paper_session_state.json
TAX_CSV_PATH=tax_trades.csv
TAX_MONTHLY_CSV_PATH=tax_summary_monthly.csv
TAX_YEARLY_CSV_PATH=tax_summary_yearly.csv
