# Wallet (never commit real keys)
SOLANA_PRIVATE_KEY=
SOLANA_NETWORK=mainnet-beta
SOLANA_RPC_URL=

# Jupiter (optional API key from https://portal.jup.ag improves rate limits)
JUPITER_API_KEY=
# Defaults use lite-api.jup.ag (v6 endpoints are sunset)
# JUPITER_QUOTE_API=https://lite-api.jup.ag/swap/v1/quote
# JUPITER_SWAP_API=https://lite-api.jup.ag/swap/v1/swap
# JUPITER_PRICE_API=https://api.jup.ag/price/v3
# Jupiter rate limiting (shared client paces all quote/price/swap calls)
JUPITER_REQUEST_DELAY_SEC=0.75
JUPITER_PRICE_CACHE_TTL_SEC=20
JUPITER_QUOTE_CACHE_TTL_SEC=15

# Scanner API keys (optional — see README "Scanner API keys")
# DexScreener: public API needs no key today (60 req/min). pump.fun: public endpoints work without JWT.
# Optional: PUMPFUN_API_BASE=https://frontend-api.pump.fun (default) or https://frontend-api-v3.pump.fun
# Optional JWT: POST https://frontend-api-v3.pump.fun/auth/login — paste token as PUMPFUN_API_KEY
# Birdeye: free key at https://birdeye.so — Find Gems (1h gainers) page:
# https://birdeye.so/solana/find-gems
# Primary API: GET /defi/v3/token/meme/list (sort_by=price_change_1h_percent)
# Also uses /defi/v2/tokens/new_listing and /defi/token_trending as fallbacks.
# Without BIRDEYE_API_KEY, DexScreener trending fallback is used instead.
# GMGN.ai Solana trending: https://gmgn.ai/?chain=sol
# Public quotation API works without a key; optional GMGN_API_KEY from https://gmgn.ai/ai
DEXSCREENER_API_KEY=
PUMPFUN_API_KEY=
# PUMPFUN_API_BASE=https://frontend-api.pump.fun
BIRDEYE_API_KEY=

# GMGN.ai — Solana trending tokens (public quotation API; optional Agent API key)
# Skills market UI: https://gmgn.ai/ai?chain=sol&tab=skills_market
# Token discovery uses quotation rank API (mint in `address` field):
#   GET /defi/quotation/v1/rank/sol/swaps/{1m|5m|1h|...}?orderby=volume|swaps|price_change
# Optional key from https://gmgn.ai/ai for Agent API (gmgn-cli / GET /v1/market/rank)
GMGN_ENABLED=true
SCAN_GMGN=true
GMGN_API_KEY=
GMGN_TIMEFRAME=1h
GMGN_TRENDING_LIMIT=30
GMGN_REQUEST_DELAY_SEC=1.0
# GMGN_SAFETY_FILTERS=not_honeypot
# GMGN_MIN_LIQUIDITY_USD=
# GMGN_MIN_VOLUME_24H_USD=
# GMGN_MIN_MOMENTUM_PCT=

# Strategy (Best Win defaults — see BEST_WIN_STRATEGY.md)
# Set true to auto-apply BEST_WIN_STRATEGY_PRESET on server start (saves bookmark first)
# BEST_WIN_STRATEGY=true
ENTRY_MOMENTUM_PCT=0.005
TARGET_NET_PROFIT_SOL=0.0155
MIN_EXPECTED_NET_PROFIT_SOL=0.002
MOVE_SL_TO_BREAKEVEN_AFTER_L1=true
LADDER_EARLY_EXIT_LEVELS=2
MOMENTUM_SLOWDOWN_PCT=0.5
WEAKEN_EXIT_ENABLED=true
WEAKEN_EXIT_MIN_PROFIT_PCT=0.01
INSTANT_PROFIT_EXIT_ENABLED=true
INSTANT_EXIT_3PCT=0.0325
INSTANT_PROFIT_EXIT_PCT=0.05
FEE_BUFFER_SOL=
# Ladder partials disabled — instant full exits at +3.25% / +5%.
TAKE_PROFIT_LEVELS=
TAKE_PROFIT_PORTIONS=
ENABLE_L1_PROTECTION=false
# Allowed: 0.015 (1.5%), 0.02 (2.0%), 0.03 (3.0%), 0.05 (5.0%) — GUI dropdown matches these values
STOP_LOSS_PCT=0.02
STOP_LOSS_NEVER_MISS=true
LOSS_FRESH_QUOTE_PCT=0.01
TIME_STOP_MINUTES=30
LADDER_MISSED_POSITIVE_EXIT_MINUTES=10
LADDER_MISSED_NEGATIVE_DCA_MINUTES=30
MAX_BUYS_PER_MINT=3
ENABLE_LADDER_TIME_EXITS=true
# Non-WBTC max hold: force exit after N minutes (WBTC watchlist exempt)
MAX_HOLD_ENABLED=true
MAX_HOLD_MINUTES_NON_WBTC=15

# Scanner filters (session-tuned: $25,000 min pool liquidity)
MIN_LIQUIDITY_USD=30000
PUMPFUN_MIN_LIQUIDITY_USD=
PUMPFUN_MIN_MARKET_CAP_USD=5000
PUMPFUN_MAX_AGE_MINUTES=0
# PUMPFUN_MIN_VOLUME_24H_USD=
# PUMPFUN_MIN_MOMENTUM_PCT=
SCAN_PUMPFUN=true
INCLUDE_PUMPFUN=true
SCAN_BIRDEYE=true
BIRDEYE_FIND_GEMS_ENABLED=true
BIRDEYE_GAINER_TIMEFRAME=1h
BIRDEYE_MIN_LIQUIDITY_USD=
BIRDEYE_MIN_VOLUME_24H_USD=
