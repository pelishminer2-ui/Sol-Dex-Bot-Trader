# Best Win strategy — copy values into .env or use GUI "Best Win" button
# Paper and live share the same strategy; only balance source differs.

# --- Core sizing ---
TRADE_SIZE_SOL=0.10
ENTRY_MOMENTUM_PCT=0.0075
STOP_LOSS_PCT=0.015
WBTC_STOP_LOSS_PCT=0.02

# --- Profit-first gates ---
MIN_EXPECTED_NET_PROFIT_SOL=0.002
MIN_NET_WIN_SOL=0.002
TARGET_NET_PROFIT_SOL=0.0155
LOSS_REENTRY_COOLDOWN_MINUTES=90
LOSS_REENTRY_REPEAT_COOLDOWN_MINUTES=180
MAX_LOSS_PER_TRADE_SOL=0.012

# --- Ladder exits ---
TAKE_PROFIT_LEVELS=0.03,0.04
TAKE_PROFIT_PORTIONS=0.5,0.5
L1_PROTECTION_PCT=0.001
ENABLE_L1_PROTECTION=true
INSTANT_PROFIT_EXIT_ENABLED=true
INSTANT_PROFIT_EXIT_PCT=0.05
WEAKEN_EXIT_ENABLED=true
WEAKEN_EXIT_MIN_PROFIT_PCT=0.01
LADDER_MISSED_POSITIVE_EXIT_MINUTES=10
LADDER_MISSED_NEGATIVE_DCA_MINUTES=30
ENABLE_LADDER_TIME_EXITS=true

# --- Scanner / discovery ---
MIN_LIQUIDITY_USD=15000
MIN_VOLUME_24H_USD=40000
NON_WATCHLIST_MIN_VOLUME_24H_USD=40000
MIN_MOMENTUM_PCT=0.015
TRADE_CANDIDATE_TOP_N=10
SCAN_PUMPFUN=true
SCAN_BIRDEYE=true
SCAN_GMGN=true
BLOCK_STOCK_RELATED_TOKENS=true

# --- Position limits ---
MAX_OPEN_POSITIONS=1
MAX_OPEN_POSITIONS_WBTC=2
REENTRY_DIP_PCT=0.10

# --- Fees (paper simulates same deductions) ---
SOL_TX_FEE_LAMPORTS=5000
SOL_PRIORITY_FEE_LAMPORTS=100000
FEE_BUFFER_PCT=0.10
DEFAULT_DEX_FEE_BPS=25
DEFAULT_SLIPPAGE_BPS=100

# --- Watchlist ---
WATCHLIST_ENABLED=true
WATCHLIST_MINT=3NZ9JMVBmGAqocybic2c7LQCJScmgsAZ6vQqTDzcqmJh
WATCHLIST_MIN_USD_GAIN=75.0

# --- Mode ---
DRY_RUN=true
PAPER_SIMULATED_BALANCE_SOL=0.75
